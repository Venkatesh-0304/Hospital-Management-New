= turbo_frame_tag "tab_content" do
  %div{style: "display:flex; justify-content:center;"}
    %div
      %h1{style:"color:navy;"} Hospitals
      - if notice
        %p{color: "red"}
          =notice
  
      = link_to "New hospital", new_hospital_path
  
      %table{border: "1"}
        %thead
          %tr
            %th Name
        %tbody
          - @hospitals.each do |hospital|
            %tr    
            
              %th=link_to hospital.name, doctors_hospital_path(hospital), data: {turbo_frame: dom_id(hospital, :doctors)}
            %tr
              %td= turbo_frame_tag dom_id(hospital, :doctors)



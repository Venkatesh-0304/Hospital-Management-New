= turbo_frame_tag "tab" do
  %h1 Patients
  = turbo_frame_tag "modal"
  = link_to "New patient", new_patient_path, data: {turbo_frame: "modal"}

  %table{border: "1"}
    %thead
      %tr
        %th Name
        %th Age
        %th Gender
        %th Born On
        %th{colspan: "3"} Actions

    %tbody#patients
      = render @patients